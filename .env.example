# wagw-shimmy — shim configuration. Copy to .env (never commit a filled-in copy).
# On a fleet box this is rendered to /etc/wagw-shimmy.env (0600) by deploy/render-env.sh.

# --- Listener ---
# Stays on localhost: the data plane never leaves the box. Only /healthz is also exposed on the
# tailnet interface by the systemd unit (see deploy/).
SHIM_BIND=127.0.0.1:8080

# --- Upstream GOWA (same box, localhost) ---
GOWA_URL=http://127.0.0.1:3000
GOWA_BASIC_AUTH=admin:change-me            # GOWA REST basic auth (user:pass)
GOWA_DEVICE_ID=                            # X-Device-Id = the linked WA JID (also the bot's own JID)
# HMAC secret the shim uses to verify inbound GOWA webhooks. MUST match GOWA's
# WHATSAPP_WEBHOOK_SECRET and MUST NOT be GOWA's default 'secret' (boot will refuse it).
GOWA_WEBHOOK_SECRET=

# --- Downstream agent (same box, localhost) ---
AGENT_INBOUND_URL=http://127.0.0.1:3001    # → POST {base}/whatsapp/inbound
WHATSAPP_WEBHOOK_TOKEN=                     # bearer the shim SENDS to the agent on inbound
WHATSAPP_GATEWAY_TOKEN=                     # bearer the shim REQUIRES on its own POST /send

# --- Policy ---
WA_DM_POLICY=allowlist                      # open | allowlist | off
WA_DM_ALLOW=61400111222,61400999000         # bare numbers, +-prefixed, or full JIDs
WA_GROUP_POLICY=off                         # off | allowlist | open
WA_GROUP_ALLOW=120363000000000000@g.us      # group JIDs (… @g.us)
WA_REQUIRE_MENTION=true                     # "mention" = reply-to-bot (no GOWA patch)
WA_FREE_RESPONSE_CHATS=                      # group JIDs that bypass require-mention

# --- Rate limit (ToS protection) ---
WA_SEND_RATE_PER_MIN=20

# --- Logging ---
RUST_LOG=info
