# wagw-shimmy — shim configuration. Copy to .env (never commit a filled-in copy).
# On a fleet box this is rendered to /etc/wagw-shimmy.env (0600) by deploy/render-env.sh.
#
# Secrets: each of GOWA_BASIC_AUTH, GOWA_WEBHOOK_SECRET, WHATSAPP_WEBHOOK_TOKEN, and
# WHATSAPP_GATEWAY_TOKEN can be supplied either directly (as below) OR via a <NAME>_FILE pointing at
# a file (the direct value wins). On the fleet, the systemd unit uses LoadCredential= + <NAME>_FILE
# so the secret never enters the process environment (/proc); for a local run, set them directly.

# --- Listener ---
# Stays on localhost: the data plane never leaves the box. Only /healthz is also exposed on the
# tailnet interface by the systemd unit (see deploy/).
SHIM_BIND=127.0.0.1:8080

# --- Upstream GOWA (same box, localhost) ---
GOWA_URL=http://127.0.0.1:3000
GOWA_BASIC_AUTH=admin:change-me            # GOWA REST basic auth (user:pass)
GOWA_DEVICE_ID=                            # X-Device-Id = the linked WA JID (also the bot's own JID)
# HMAC secret the shim uses to verify inbound GOWA webhooks. MUST match GOWA's
# WHATSAPP_WEBHOOK_SECRET and MUST NOT be GOWA's default 'secret' (boot will refuse it).
GOWA_WEBHOOK_SECRET=

# --- Downstream agent (same box, localhost) ---
AGENT_INBOUND_URL=http://127.0.0.1:3001    # → POST {base}/whatsapp/inbound
WHATSAPP_WEBHOOK_TOKEN=                     # bearer the shim SENDS to the agent on inbound
WHATSAPP_GATEWAY_TOKEN=                     # bearer the shim REQUIRES on its own POST /send

# Bot's own number (digits / +-prefixed / full JID accepted). Enables group @-mention detection:
# GOWA rewrites a tag of the bot into the message body as "@<this number>", so when set, an @-tag of
# the bot in a group counts as a mention (wakes it under WA_REQUIRE_MENTION). Unset → only reply-to-bot
# counts as a mention, which can't bootstrap a fresh group thread.
WA_SELF_NUMBER=61413118079

# --- Policy ---
WA_DM_POLICY=allowlist                      # open | allowlist | off
WA_DM_ALLOW=61400111222,61400999000         # bare numbers, +-prefixed, or full JIDs
WA_GROUP_POLICY=off                         # off | allowlist | open
WA_GROUP_ALLOW=120363000000000000@g.us      # group JIDs (… @g.us)
WA_REQUIRE_MENTION=true                     # DEFAULT true (unset → true). In a group, reply only when
                                            # addressed: an @-tag of WA_SELF_NUMBER, or a reply to one
                                            # of the bot's own messages. Set false to answer everything.
WA_FREE_RESPONSE_CHATS=                      # group JIDs that bypass require-mention

# --- Per-group channel routing (optional; unset → single "default" channel = today's behaviour) ---
# Route specific groups to different downstream agents ("channels"). Every forward carries a
# "channel" label so a downstream persona can be selected later even when two groups share a target.
# Unmapped groups and all DMs always route to the implicit "default" channel (AGENT_INBOUND_URL +
# WHATSAPP_WEBHOOK_TOKEN). A group given a channel is implicitly admitted (folded into WA_GROUP_ALLOW).
#
# WA_CHANNELS: comma list of EXTRA channel labels ([a-z0-9_]; "default" is reserved/implicit).
# WA_CHANNELS=support,ops
# Per label L (env name uppercased): a base URL (/whatsapp/inbound is appended, like AGENT_INBOUND_URL)
# and an OPTIONAL bearer (defaults to WHATSAPP_WEBHOOK_TOKEN; supports a <NAME>_FILE form like the
# other secrets). Omit the token when the channel's agent shares the default inbound bearer.
# WA_CHANNEL_SUPPORT_URL=http://127.0.0.1:3002
# WA_CHANNEL_SUPPORT_TOKEN=
# WA_CHANNEL_OPS_URL=http://127.0.0.1:3003
# WA_GROUP_CHANNELS: <group-jid>:<label> pairs mapping groups → channels.
# WA_GROUP_CHANNELS=120363000000000000@g.us:support,120363111111111111@g.us:ops

# --- Rate limit (ToS protection) ---
WA_SEND_RATE_PER_MIN=20

# --- Durable forward queue (inbound → agent) ---
# A failed agent forward (agent down / non-2xx / shim crash) survives here instead of being lost:
# accepted inbound messages are written to <SHIM_QUEUE_DIR>/pending/ before GOWA is acked, and a
# bounded worker drains them with backoff retries; exhausted ones move to <SHIM_QUEUE_DIR>/dead/.
SHIM_QUEUE_DIR=/var/lib/wagw/shim/queue
SHIM_FORWARD_MAX_RETRIES=5                   # backoff retries before dead-lettering
SHIM_FORWARD_CONCURRENCY=4                   # max concurrent forwards drained from the queue
SHIM_FORWARD_BACKOFF_MS=1000                 # base backoff (doubles per attempt, capped at 60s)

# --- Readiness (/readyz) ---
# /livez is process-only; /readyz probes GOWA's /devices. Set this to also probe the agent's
# /health — off by default because the agent is now a peered box (cross-box coupling).
SHIM_READYZ_PROBE_AGENT=false

# --- Debug sink (no agent target) ---
# Run the gateway WITHOUT an agent: inbound still flows through HMAC → parse → policy → durable
# queue, but the forward is logged and discarded (nothing dead-letters). Use it to validate the
# GOWA⟷shim connection before the agent is wired. /readyz reports agent:{debug_sink:true} and boot
# logs a warning. MUST be off (false/unset) in front of real tenant traffic.
SHIM_DEBUG_SINK=false

# --- Logging ---
RUST_LOG=info
